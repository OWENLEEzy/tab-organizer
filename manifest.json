{
  "manifest_version": 3,
  "name": "Tab Organizer",
  "version": "2.0.0",
  "description": "Keep tabs on your tabs. Open a dashboard that groups your tabs by domain and lets you close them with style.",
  "permissions": ["tabs", "storage", "favicon"],
  "incognito": "not_allowed",
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Tab Organizer",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:"
  }
}
